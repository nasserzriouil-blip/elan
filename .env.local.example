# Copie ce fichier en .env.local et colle ta clé API Anthropic.
# Tu obtiens une clé sur https://console.anthropic.com/ (Settings -> API Keys).
# Cette clé reste côté serveur, elle n'est JAMAIS envoyée au navigateur.
ANTHROPIC_API_KEY=sk-ant-...

# Code d'accès de l'app. Si vide, l'app est ouverte (pratique en local).
# Définis-le en ligne (sur Vercel) pour protéger ta clé API d'un usage public.
ACCESS_PASSWORD=

